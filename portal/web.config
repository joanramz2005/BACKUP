<?xml version="1.0" encoding="UTF-8"?>
<!--
    web.config — KeepNAS Portal (IIS 10, Windows Server 2019)
    Autenticación: formulario HTML + PHP API + net use SMB
-->
<configuration>
    <system.webServer>

        <!-- ── AUTENTICACIÓN ANÓNIMA (el login lo gestiona PHP) ── -->
        <security>
            <authentication>
                <anonymousAuthentication enabled="true" />
                <windowsAuthentication enabled="false" />
            </authentication>

            <!-- Solo acceso desde la VPN WireGuard 10.10.0.0/24 -->
            <ipSecurity allowUnlisted="false" denyAction="Forbidden">
                <add ipAddress="10.10.0.0" subnetMask="255.255.255.0" allowed="true" />
                <add ipAddress="127.0.0.1" allowed="true" />
                <add ipAddress="::1" allowed="true" />
            </ipSecurity>
        </security>

        <!-- ── HTTP → HTTPS ── -->
        <rewrite>
            <rules>
                <rule name="HTTP to HTTPS" stopProcessing="true">
                    <match url="(.*)" />
                    <conditions>
                        <add input="{HTTPS}" pattern="^OFF$" />
                    </conditions>
                    <action type="Redirect" url="https://{HTTP_HOST}/{R:1}" redirectType="Permanent" />
                </rule>
            </rules>
        </rewrite>

        <!-- ── CABECERAS DE SEGURIDAD ── -->
        <httpProtocol>
            <customHeaders>
                <add name="Strict-Transport-Security" value="max-age=31536000; includeSubDomains" />
                <add name="X-Content-Type-Options"    value="nosniff" />
                <add name="X-Frame-Options"           value="DENY" />
                <add name="Referrer-Policy"            value="strict-origin-when-cross-origin" />
                <add name="Content-Security-Policy"   value="default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data:;" />
                <remove name="X-Powered-By" />
                <remove name="Server" />
            </customHeaders>
        </httpProtocol>

        <!-- ── HANDLER PHP ── -->
        <handlers>
            <remove name="PHP_via_FastCGI" />
            <add name="PHP_via_FastCGI"
                 path="*.php" verb="GET,POST,HEAD"
                 modules="FastCgiModule"
                 scriptProcessor="C:\PHP\php-cgi.exe"
                 resourceType="Either" requireAccess="Script" />
        </handlers>

        <!-- ── SUBIDA MÁXIMA: 500 MB ── -->
        <requestFiltering>
            <requestLimits maxAllowedContentLength="524288000" />
            <fileExtensions allowUnlisted="true">
                <add fileExtension=".exe" allowed="false" />
                <add fileExtension=".bat" allowed="false" />
                <add fileExtension=".cmd" allowed="false" />
                <add fileExtension=".ps1" allowed="false" />
                <add fileExtension=".vbs" allowed="false" />
                <add fileExtension=".msi" allowed="false" />
            </fileExtensions>
        </requestFiltering>

        <!-- ── DOCUMENTO PREDETERMINADO ── -->
        <defaultDocument>
            <files>
                <clear />
                <add value="login.html" />
            </files>
        </defaultDocument>

        <!-- ── MIME TYPES para JS/CSS ── -->
        <staticContent>
            <mimeMap fileExtension=".js"  mimeType="application/javascript" />
            <mimeMap fileExtension=".css" mimeType="text/css" />
        </staticContent>

    </system.webServer>
</configuration>
